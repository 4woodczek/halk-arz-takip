import React, { useState, useEffect } from 'react';
import { Plus, Trash2, CircleDollarSign, AlertCircle, TrendingUp, Award, BarChart3, Target } from 'lucide-react';

// Ana Uygulama Bileşeni
export default function App() {
  // Verileri LocalStorage'dan yükle (Kalıcılık için v3 etiketi kullanıldı)
  const [stocks, setStocks] = useState(() => {
    if (typeof window !== 'undefined') {
      try {
        const saved = localStorage.getItem('halka_arz_portfolio_2026_v3');
        return saved ? JSON.parse(saved) : [];
      } catch (error) {
        console.error("Veri yüklenemedi:", error);
        return [];
      }
    }
    return [];
  });

  const [newStock, setNewStock] = useState({
    name: '',
    buyPrice: '',
    lot: '',
    sellPrice: ''
  });

  const [deleteConfirm, setDeleteConfirm] = useState(null);

  // Veriler değiştikçe telefona/tarayıcıya kalıcı olarak kaydet
  useEffect(() => {
    localStorage.setItem('halka_arz_portfolio_2026_v3', JSON.stringify(stocks));
  }, [stocks]);

  const addStock = (e) => {
    e.preventDefault();
    if (!newStock.name || !newStock.buyPrice || !newStock.lot) return;
    
    setStocks([{ ...newStock, id: Date.now() }, ...stocks]);
    setNewStock({ name: '', buyPrice: '', lot: '', sellPrice: '' });
  };

  const executeDelete = () => {
    setStocks(stocks.filter(s => s.id !== deleteConfirm));
    setDeleteConfirm(null);
  };

  const calculateStats = (stock) => {
    const cost = parseFloat(stock.buyPrice) * parseFloat(stock.lot) || 0;
    const revenue = stock.sellPrice ? parseFloat(stock.sellPrice) * parseFloat(stock.lot) : 0;
    const profit = stock.sellPrice ? revenue - cost : 0;
    const percentage = (stock.sellPrice && cost > 0) ? ((profit / cost) * 100).toFixed(1) : 0;
    
    return { cost, revenue, profit, percentage };
  };

  const totalProfit = stocks.reduce((acc, stock) => {
    const { profit } = calculateStats(stock);
    return acc + profit;
  }, 0);

  const getPerformanceMetrics = () => {
    if (stocks.length === 0) return { best: '-', winRate: 0, count: 0 };
    
    const calculated = stocks.map(s => calculateStats(s));
    const maxPerc = Math.max(...calculated.map(c => parseFloat(c.percentage)));
    const bestStock = stocks[calculated.findIndex(c => parseFloat(c.percentage) === maxPerc)];
    const wins = calculated.filter(s => s.profit > 0).length;
    
    return {
      best: bestStock ? bestStock.name : '-',
      winRate: ((wins / stocks.length) * 100).toFixed(0),
      count: stocks.length
    };
  };

  const metrics = getPerformanceMetrics();

  return (
    <div className="min-h-screen bg-[#0F172A] p-3 md:p-8 font-sans text-slate-200 selection:bg-indigo-500/30">
      <div className="max-w-5xl mx-auto">
        
        {/* Onay Modalı */}
        {deleteConfirm && (
          <div className="fixed inset-0 bg-black/90 backdrop-blur-md z-[100] flex items-center justify-center p-4">
            <div className="bg-[#1E293B] rounded-[2.5rem] p-8 max-w-sm w-full shadow-2xl border border-slate-700/50">
              <div className="flex flex-col items-center text-center">
                <div className="w-16 h-16 bg-rose-500/10 text-rose-500 rounded-full flex items-center justify-center mb-4 border border-rose-500/20">
                  <AlertCircle size={32} />
                </div>
                <h3 className="text-xl font-black text-white mb-2 tracking-tight">Emin misiniz?</h3>
                <p className="text-slate-400 text-sm font-medium mb-8">Bu işlem verilerini cihazınızdan kalıcı olarak siler.</p>
                <div className="flex gap-3 w-full">
                  <button onClick={() => setDeleteConfirm(null)} className="flex-1 px-6 py-4 bg-slate-800 text-slate-300 font-bold rounded-2xl hover:bg-slate-700 transition-colors">Vazgeç</button>
                  <button onClick={executeDelete} className="flex-1 px-6 py-4 bg-rose-600 text-white font-bold rounded-2xl shadow-lg hover:bg-rose-500 transition-colors">Sil</button>
                </div>
              </div>
            </div>
          </div>
        )}

        {/* Üst Kısım: Başlık ve Kar Durumu */}
        <div className="mb-6 flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div className="px-1">
            <div className="flex items-center gap-3 mb-2">
              <div className="bg-indigo-500 p-2 rounded-lg text-white shadow-lg shadow-indigo-500/20">
                <TrendingUp size={18} />
              </div>
              <h1 className="text-[10px] font-black text-slate-500 tracking-[0.2em] uppercase">Halka Arz Takip v3.0</h1>
            </div>
            <div className="flex items-baseline gap-2">
              <p className={`text-4xl md:text-5xl font-black tracking-tight ${totalProfit >= 0 ? 'text-emerald-400' : 'text-rose-400'}`}>
                {totalProfit.toLocaleString('tr-TR', { minimumFractionDigits: 2 })}
              </p>
              <span className="text-sm font-bold text-slate-500 uppercase">TL Kar</span>
            </div>
          </div>
          
          {/* Performans Kartları */}
          <div className="grid grid-cols-3 gap-2 md:flex md:gap-4">
            <div className="bg-[#1E293B] px-3 py-3 rounded-2xl border border-slate-700/50 shadow-xl flex flex-col md:flex-row items-center md:gap-4 text-center">
              <div className="w-8 h-8 bg-amber-500/10 text-amber-500 rounded-full flex items-center justify-center border border-amber-500/20 mb-1 md:mb-0">
                <Award size={16} />
              </div>
              <div>
                <p className="text-[8px] font-black text-slate-500 uppercase tracking-widest">En İyi</p>
                <p className="text-xs font-black text-white truncate max-w-[60px]">{metrics.best}</p>
              </div>
            </div>
            <div className="bg-[#1E293B] px-3 py-3 rounded-2xl border border-slate-700/50 shadow-xl flex flex-col md:flex-row items-center md:gap-4 text-center">
              <div className="w-8 h-8 bg-indigo-500/10 text-indigo-400 rounded-full flex items-center justify-center border border-indigo-500/20 mb-1 md:mb-0">
                <Target size={16} />
              </div>
              <div>
                <p className="text-[8px] font-black text-slate-500 uppercase tracking-widest">Başarı</p>
                <p className="text-xs font-black text-white">%{metrics.winRate}</p>
              </div>
            </div>
            <div className="bg-[#1E293B] px-3 py-3 rounded-2xl border border-slate-700/50 shadow-xl flex flex-col md:flex-row items-center md:gap-4 text-center">
              <div className="w-8 h-8 bg-slate-700/50 text-slate-400 rounded-full flex items-center justify-center border border-slate-600/50 mb-1 md:mb-0">
                <BarChart3 size={16} />
              </div>
              <div>
                <p className="text-[8px] font-black text-slate-500 uppercase tracking-widest">Adet</p>
                <p className="text-xs font-black text-white">{metrics.count}</p>
              </div>
            </div>
          </div>
        </div>

        {/* Veri Giriş Alanı */}
        <div className="bg-[#1E293B] p-5 md:p-8 rounded-[2rem] shadow-2xl border border-slate-700/50 mb-8">
          <form onSubmit={addStock} className="grid grid-cols-2 lg:grid-cols-5 gap-4 items-end">
            <div className="space-y-1.5 col-span-2 md:col-span-1">
              <label className="text-[9px] font-black text-slate-500 ml-1 uppercase tracking-widest">Hisse Kodu</label>
              <input type="text" placeholder="KOD" className="w-full p-3.5 rounded-xl bg-[#0F172A] border border-slate-700 text-white focus:border-indigo-500 outline-none uppercase font-black text-sm" value={newStock.name} onChange={e => setNewStock({...newStock, name: e.target.value.toUpperCase()})} />
            </div>
            <div className="space-y-1.5">
              <label className="text-[9px] font-black text-slate-500 ml-1 uppercase tracking-widest">Alış Fiyatı</label>
              <input type="number" step="0.01" placeholder="0.00" className="w-full p-3.5 rounded-xl bg-[#0F172A] border border-slate-700 text-white focus:border-indigo-500 outline-none font-black text-sm" value={newStock.buyPrice} onChange={e => setNewStock({...newStock, buyPrice: e.target.value})} />
            </div>
            <div className="space-y-1.5">
              <label className="text-[9px] font-black text-slate-500 ml-1 uppercase tracking-widest">Lot Adedi</label>
              <input type="number" placeholder="0" className="w-full p-3.5 rounded-xl bg-[#0F172A] border border-slate-700 text-white focus:border-indigo-500 outline-none font-black text-sm" value={newStock.lot} onChange={e => setNewStock({...newStock, lot: e.target.value})} />
            </div>
            <div className="space-y-1.5 col-span-2 md:col-span-1">
              <label className="text-[9px] font-black text-indigo-400 ml-1 uppercase tracking-widest">Satış (Opsiyonel)</label>
              <input type="number" step="0.01" placeholder="Satış Fiyatı" className="w-full p-3.5 rounded-xl bg-indigo-500/5 border border-indigo-500/30 text-indigo-300 focus:border-indigo-500 outline-none font-black text-sm" value={newStock.sellPrice} onChange={e => setNewStock({...newStock, sellPrice: e.target.value})} />
            </div>
            <button type="submit" className="col-span-2 md:col-span-1 bg-white hover:bg-indigo-500 hover:text-white text-[#0F172A] font-black p-3.5 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-95 shadow-xl uppercase text-[10px] tracking-widest">
              <Plus size={16} /> Ekle
            </button>
          </form>
        </div>

        {/* Portföy Listesi */}
        <div className="space-y-3 pb-20">
          <div className="flex items-center justify-between px-2 mb-2">
            <h2 className="text-[9px] font-black text-slate-600 uppercase tracking-[0.25em]">Güncel Portföy</h2>
            <div className="h-px bg-slate-800/50 flex-1 mx-4"></div>
          </div>

          {stocks.length === 0 ? (
            <div className="bg-[#1E293B]/30 p-16 rounded-[2.5rem] border-2 border-dashed border-slate-800 text-center">
              <CircleDollarSign size={40} className="mx-auto mb-3 text-slate-800" />
              <p className="text-slate-600 font-bold uppercase text-[9px] tracking-[0.2em]">Henüz bir hisse eklemediniz.</p>
            </div>
          ) : (
            <div className="grid grid-cols-1 gap-3">
              {stocks.map(stock => {
                const stats = calculateStats(stock);
                return (
                  <div key={stock.id} className="bg-[#1E293B] p-4 rounded-[1.5rem] shadow-xl border border-slate-700/30 flex flex-col md:flex-row items-center justify-between gap-4 transition-transform active:scale-[0.98]">
                    {/* Hisse Bilgisi */}
                    <div className="flex items-center gap-4 w-full md:w-auto">
                      <div className={`w-12 h-12 rounded-xl flex items-center justify-center font-black text-xs border shadow-inner shrink-0
                        ${stock.sellPrice ? (stats.profit >= 0 ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' : 'bg-rose-500/10 text-rose-400 border-rose-500/20') : 'bg-slate-800 text-slate-500 border-slate-700'}`}>
                        {stock.name.substring(0, 3)}
                      </div>
                      <div className="flex-1">
                        <h3 className="font-black text-lg text-white leading-none mb-1">{stock.name}</h3>
                        <p className="text-[9px] text-slate-500 font-black uppercase tracking-wider">{stock.lot} LOT • {stock.buyPrice} TL</p>
                      </div>
                      <button onClick={() => setDeleteConfirm(stock.id)} className="md:hidden text-slate-700 p-2">
                        <Trash2 size={18} />
                      </button>
                    </div>

                    {/* Finansal Detaylar */}
                    <div className="grid grid-cols-3 gap-2 w-full flex-1 border-y md:border-y-0 border-slate-800 py-3 md:py-0">
                      <div className="text-center">
                        <p className="text-[8px] font-black text-slate-500 uppercase tracking-widest">Maliyet</p>
                        <p className="text-xs font-bold text-slate-300">{stats.cost.toLocaleString('tr-TR')}</p>
                      </div>
                      <div className="text-center">
                        <p className="text-[8px] font-black text-indigo-400/70 uppercase tracking-widest">Satış</p>
                        <p className="text-xs font-black text-indigo-400">{stock.sellPrice ? parseFloat(stock.sellPrice).toLocaleString('tr-TR') : '---'}</p>
                      </div>
                      <div className="text-center">
                        <p className="text-[8px] font-black text-slate-500 uppercase tracking-widest">Net Kar</p>
                        <p className={`text-xs font-black ${stats.profit >= 0 ? 'text-emerald-400' : 'text-rose-400'}`}>
                          {stock.sellPrice ? stats.profit.toLocaleString('tr-TR') : '---'}
                        </p>
                      </div>
                    </div>

                    {/* Kar Oranı ve Aksiyon */}
                    <div className="flex items-center justify-between md:justify-end gap-4 w-full md:w-auto">
                      <div className="w-full md:w-auto">
                        {stock.sellPrice ? (
                          <div className={`text-[9px] font-black px-4 py-1.5 rounded-full uppercase text-center min-w-[70px]
                              ${stats.profit >= 0 ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-rose-500/10 text-rose-400 border border-rose-500/20'}`}>
                              %{stats.percentage}
                          </div>
                        ) : (
                          <div className="text-[9px] font-black text-amber-500 bg-amber-500/5 px-4 py-1.5 rounded-full border border-amber-500/20 tracking-[0.1em] uppercase animate-pulse text-center min-w-[70px]">
                            Bekliyor
                          </div>
                        )}
                      </div>
                      <button onClick={() => setDeleteConfirm(stock.id)} className="hidden md:block text-slate-700 hover:text-rose-500 p-2 transition-colors">
                        <Trash2 size={18} />
                      </button>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
